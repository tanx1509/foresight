# Backend server
PORT=3001
PUBLIC_APP_URL=http://localhost:3000
PUBLIC_API_URL=http://localhost:3001

# Azure OpenAI
# Get these from Azure Portal -> Azure OpenAI resource -> Keys and Endpoint,
# then Azure AI Foundry / Azure OpenAI Studio -> Deployments.
AZURE_OPENAI_ENDPOINT=https://YOUR-RESOURCE.openai.azure.com
AZURE_OPENAI_API_KEY=YOUR_AZURE_OPENAI_KEY
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-10-21

# Azure AI Search, optional unless SEARCH_PROVIDER=azure.
AZURE_SEARCH_ENDPOINT=https://YOUR-SEARCH-SERVICE.search.windows.net
AZURE_SEARCH_KEY=YOUR_AZURE_SEARCH_ADMIN_OR_QUERY_KEY
AZURE_SEARCH_INDEX=foresight-memory
AZURE_SEARCH_API_VERSION=2024-07-01

# Azure DevOps
# Get ORG_URL from your Azure DevOps organization URL.
# Get PROJECT and TEAM from Azure DevOps project/team settings.
# Create PAT in Azure DevOps -> User settings -> Personal access tokens.
AZURE_DEVOPS_ORG_URL=https://dev.azure.com/YOUR_ORG
AZURE_DEVOPS_PROJECT=YOUR_PROJECT
AZURE_DEVOPS_TEAM=YOUR_TEAM
AZURE_DEVOPS_PAT=YOUR_PAT_WITH_WORK_ITEMS_READ_WRITE
AZURE_DEVOPS_WORK_ITEM_TYPE=Issue

# Provider switches: mock keeps the app runnable without cloud services.
SEARCH_PROVIDER=mock
OPERATIONAL_PROVIDER=mock

# Microsoft Teams outgoing channel notification
# Get from Teams channel -> Workflows/Incoming Webhook, or Power Automate HTTP trigger.
TEAMS_WEBHOOK_URL=https://YOUR_TEAMS_WEBHOOK_URL
TEAMS_BOT_APP_ID=
TEAMS_BOT_PASSWORD=
TEAMS_CHANNEL_ID=

# Microsoft Copilot / Copilot Studio
# Use a Copilot Studio action/custom connector or Power Automate HTTP trigger URL.
COPILOT_WEBHOOK_URL=https://YOUR_COPILOT_OR_POWER_AUTOMATE_WEBHOOK_URL
COPILOT_API_KEY=
COPILOT_AGENT_ID=
COPILOT_TENANT_ID=

# ShareChat
# Use your ShareChat business/developer webhook, or an automation bridge URL.
SHARECHAT_WEBHOOK_URL=https://YOUR_SHARECHAT_WEBHOOK_OR_BRIDGE_URL
SHARECHAT_BOT_TOKEN=
SHARECHAT_CHANNEL_ID=
