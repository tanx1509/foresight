{
  "name": "foresight",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=20 <23",
    "npm": ">=10"
  },
  "workspaces": [
    "frontend",
    "backend",
    "shared",
    "mock-data"
  ],
  "scripts": {
    "dev": "node scripts/dev.js",
    "dev:backend": "npm run dev --workspace @foresight/backend",
    "dev:frontend": "npm run dev --workspace frontend",
    "build": "npm run build --workspaces --if-present",
    "start": "npm run start --workspace @foresight/backend --if-present"
  },
  "devDependencies": {
    "@types/pdfkit": "^0.17.6",
    "docx": "^9.7.1",
    "pdfkit": "^0.18.0",
    "puppeteer": "^25.1.0"
  }
}
